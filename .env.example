# Telegram Bot Configuration
# Required: Your Telegram bot token from @BotFather
# Format: "1234567890:ABCdefGHIjklMNOpqrsTUVwxyz"
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Required: Comma-separated list of Telegram group chat IDs
# Format: "-1001234567890,-1009876543210"
# To get group IDs: Add the bot to your groups and use the /getid command or check bot logs
GROUP_IDS=-1001234567890,-1009876543210

# Optional: Port for the keep-alive web server (defaults to 8080)
# Render platform will set this automatically
PORT=8080
